---
import '../styles/tokens.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Strategic L&D — A strategy design office for L&D teams',
  description = 'A strategy design office for L&D teams that want to be more efficient and more strategic.',
  current = '',
  hideChrome = false,  // when true: no global Header (incl. top util strip) and no Footer.
  immersiveBg,         // CSS color to apply to the body when hideChrome is on
                       //   (e.g. 'var(--ink)' for dark pages, 'var(--paper)' for light).
                       //   Avoids any chrome-coloured edge on scroll bounce.
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  {/* TODO: OG image generation. Per-post 1200x630 PNG using the brand template,
       carrying "Field Note No. XX" and the title. Likely implemented as an Astro
       endpoint at /og/[slug].png using satori or @vercel/og. */}
</head>
<body
  class={hideChrome ? 'no-chrome' : ''}
  style={hideChrome && immersiveBg ? `background: ${immersiveBg};` : undefined}
>
  {!hideChrome && <Header current={current} />}
  <slot />
  {!hideChrome && <Footer />}
</body>
</html>
