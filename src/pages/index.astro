---
import BaseLayout from '../layouts/BaseLayout.astro';
import Availability from '../components/Availability.astro';
import ContactCTA from '../components/ContactCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const principles = [
  'Content is not training.',
  'Training must reflect reality as close as possible.',
  'The goal is to improve performance.',
  'Skills are developed over time, not in one sitting.',
  "People must care about what they're learning.",
  'Information supports skill development, it does not create skills.',
  'Measure change, quality and results.',
  'Assessment is practice with a score.',
  'Learning is mental, physical and emotional.',
  'Technology is only a problem when the above is ignored.',
];

// map a principle to a post slug if one exists
const postByPrinciple = new Map(
  posts.filter((p) => p.data.principle).map((p) => [p.data.principle, p.id])
);
---
<BaseLayout current="home">
  <main>
    <!-- HERO -->
    <section class="hero">
      <h1>L&amp;D teams do their best work when they are <span class="accent">strategic</span>.</h1>
      <p class="deck">
        A consultancy for L&amp;D teams that want to be <strong>more efficient and more strategic</strong>. We help you cut what isn't working, sharpen what is, and operate with a point of view your business actually values. <strong>One engagement, one outcome, handed over for you to run yourselves.</strong>
      </p>
      <div class="actions">
        <a href="/#contact" class="btn-primary">Contact</a>
        <a href="/services" class="btn-secondary">See our services →</a>
      </div>
    </section>

    <!-- AVAILABILITY -->
    <Availability />

    <!-- SERVICES -->
    <div class="section-header">
      <h2>Four services. Four outcomes.</h2>
      <p class="desc">Each engagement is a defined product: scoped, priced, and built to be handed over. You commission one. We deliver it. You run it.</p>
    </div>
    <div class="catalogue">
      <article class="cat-item">
        <div class="cat-head"><span><span class="swatch-mini" style="background:var(--signal)"></span><strong>A-01</strong> · Foundations</span><span>2–3 weeks</span></div>
        <div class="cat-body"><h3>Design Principles</h3><p>A short engagement to help your team articulate the principles that govern your L&amp;D work, so future decisions about scope, format, and quality become faster and more consistent.</p></div>
        <div class="cat-foot"><a class="cta" href="/#contact">Create your design principles</a><span class="ref">REF. A-01</span></div>
      </article>
      <article class="cat-item">
        <div class="cat-head"><span><span class="swatch-mini" style="background:var(--sys-yellow)"></span><strong>A-02</strong> · Operations</span><span>4–8 weeks</span></div>
        <div class="cat-body"><h3>Process Design</h3><p>A review and redesign of your L&amp;D operating processes: intake, design, build, review, deployment. The team ships better work in less time, with less rework, and no rituals dressed up as method.</p></div>
        <div class="cat-foot"><a class="cta" href="/#contact">Redesign the process</a><span class="ref">REF. A-02</span></div>
      </article>
      <article class="cat-item">
        <div class="cat-head"><span><span class="swatch-mini" style="background:var(--sys-green)"></span><strong>A-03</strong> · Strategy</span><span>6–12 weeks</span></div>
        <div class="cat-body"><h3>Learning Strategy</h3><p>An organisational learning strategy that answers what the business actually needs, what L&amp;D will and won't do, and how performance will be measured. A document leadership can read in twenty minutes and act on.</p></div>
        <div class="cat-foot"><a class="cta" href="/#contact">Let's talk strategy</a><span class="ref">REF. A-03</span></div>
      </article>
      <article class="cat-item">
        <div class="cat-head"><span><span class="swatch-mini" style="background:var(--sys-blue)"></span><strong>A-04</strong> · Capability</span><span>Workshops &amp; programmes</span></div>
        <div class="cat-body"><h3>Strategic Thinking</h3><p>Workshops and programmes designed to build the strategic muscle of your L&amp;D team, so the work outlasts the engagement and your people stop being seen as order-takers.</p></div>
        <div class="cat-foot"><a class="cta" href="/#contact">Ready to be strategic?</a><span class="ref">REF. A-04</span></div>
      </article>
    </div>

    <!-- PRINCIPLES -->
    <div class="section-header" id="principles">
      <h2>Ten principles behind the work.</h2>
      <p class="desc">The point of view that runs through every engagement. Each one is written up as a short field note. Practice, not theory.</p>
    </div>
    <aside class="principles">
      <ol class="principles-list">
        {principles.map((p, i) => {
          const slug = postByPrinciple.get(i + 1);
          return (
            <li>
              {slug
                ? <a href={`/blog/${slug}`}>{p}</a>
                : <span class="pending">{p}</span>}
            </li>
          );
        })}
      </ol>
    </aside>

    <!-- METHOD -->
    <div class="section-header">
      <h2>A method, not a methodology.</h2>
      <p class="desc">Four phases. Each one ends with a decision, not a deliverable. We do not sell discovery. We do the work.</p>
    </div>
    <div class="method">
      <div class="method-step"><span class="stepnum">Step 01 / Diagnose</span><p>Interview the people doing the work. Audit the artefacts. Find what's actually slowing the team down, not what people think is slowing them down.</p><h4>Diagnose</h4></div>
      <div class="method-step"><span class="stepnum">Step 02 / Decide</span><p>Agree what the team will do, won't do, and will stop doing. Cuts come before additions. Nothing new ships until something old is removed.</p><h4>Decide</h4></div>
      <div class="method-step"><span class="stepnum">Step 03 / Design</span><p>Build the principles, the process, or the strategy. Document it in a form the team will actually use: short, plain, durable.</p><h4>Design</h4></div>
      <div class="method-step"><span class="stepnum">Step 04 / Hand over</span><p>Leave the team capable of running it themselves. No retainer dependency. No recurring fees. If you need us again, it's because something changed.</p><h4>Hand over</h4></div>
    </div>

    <!-- TRACK RECORD -->
    <div class="section-header">
      <h2>Over 15 years inside the work.</h2>
      <p class="desc">Built on L&amp;D practice across financial services, retail, energy, government, and technology. The same person doing the work today did it in-house, before consulting on it.</p>
    </div>
    <div class="metrics">
      <div class="metric"><div class="figure">15+<span class="unit">yrs</span></div><div class="mlabel">L&amp;D practice<br />across sectors</div></div>
      <div class="metric"><div class="figure">20+<span class="unit">yrs</span></div><div class="mlabel">Management<br />experience</div></div>
      <div class="metric"><div class="figure">04</div><div class="mlabel">Defined products<br />nothing custom-quoted</div></div>
      <div class="metric"><div class="figure">00</div><div class="mlabel">Retainers<br />required</div></div>
    </div>

    <!-- CONTACT -->
    <ContactCTA />
  </main>
</BaseLayout>

<style>
  main { position: relative; z-index: 5; padding: 0 var(--pad-x); max-width: var(--maxw); margin: 0 auto; }

  .hero { padding: var(--s7) 0 var(--s6); border-bottom: 2px solid var(--ink); display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--s3); align-items: end; }
  .hero h1 { grid-column: 1 / 10; font-family: var(--font-display); font-weight: 900; font-size: var(--t-display); line-height: 0.95; letter-spacing: -0.035em; }
  .hero .deck { grid-column: 1 / 8; font-size: var(--t-deck); line-height: 1.55; margin-top: var(--s4); max-width: 54ch; }
  .hero .actions { grid-column: 1 / 13; margin-top: var(--s4); display: flex; gap: var(--s3); flex-wrap: wrap; align-items: center; }

  .section-header { margin-top: var(--s7); padding-top: var(--s4); border-top: 2px solid var(--ink); }
  .section-header h2 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h2); letter-spacing: -0.025em; line-height: 1; }
  .section-header .desc { margin-top: var(--s2); font-size: var(--t-body); line-height: 1.55; color: var(--ink-soft); max-width: 60ch; }


  .catalogue { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); margin-top: var(--s4); }
  .cat-item { background: var(--paper); padding: var(--s4) 28px 28px; display: grid; grid-template-rows: auto 1fr auto; gap: var(--s3); min-height: 280px; transition: background 0.2s; }
  .cat-item:hover { background: var(--paper-2); }
  .cat-head { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); }
  .cat-head strong { color: var(--ink); font-weight: 700; }
  .cat-head .swatch-mini { display: inline-block; width: 9px; height: 9px; border-radius: 50%; vertical-align: middle; margin-right: 7px; }
  .cat-body h3 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h3); letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 10px; }
  .cat-body p { font-size: 14px; line-height: 1.55; color: var(--ink-soft); max-width: 46ch; }
  .cat-foot { display: flex; justify-content: space-between; align-items: center; padding-top: var(--s2); border-top: 1px solid var(--line-soft); }
  .cat-foot .cta { font-weight: 700; font-size: var(--t-small); letter-spacing: 0.02em; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 3px; }
  .cat-foot .cta:hover { color: var(--signal); border-color: var(--signal); }
  .cat-foot .ref { font-family: var(--font-mono); font-size: var(--t-mono-sm); letter-spacing: 0.14em; color: var(--ink-faint); }

  .principles { margin-top: var(--s4); }
  .principles-list { list-style: none; counter-reset: prin; }
  .principles-list li { counter-increment: prin; border-bottom: 1px dashed var(--line-soft); }
  .principles-list li:first-child { border-top: 1px dashed var(--line-soft); }
  .principles-list li a, .principles-list li .pending {
    display: grid; grid-template-columns: 40px 1fr auto; align-items: baseline; gap: 16px;
    padding: 18px 0; font-size: var(--t-deck); line-height: 1.4; color: var(--ink-soft); transition: color 0.15s;
  }
  .principles-list li a::before, .principles-list li .pending::before {
    content: counter(prin, decimal-leading-zero); font-family: var(--font-mono); font-size: var(--t-mono);
    color: var(--ink-faint); font-weight: 500; letter-spacing: 0.04em;
  }
  .principles-list li a::after { content: "→"; font-family: var(--font-mono); font-size: 14px; color: var(--ink-faint); transition: transform 0.2s ease, color 0.15s; }
  .principles-list li .pending::after { content: "—"; font-family: var(--font-mono); font-size: 14px; color: var(--line-soft); }
  .principles-list li a:hover { color: var(--ink); }
  .principles-list li a:hover::after { transform: translateX(4px); color: var(--signal); }
  .principles-list li .pending { cursor: default; }

  .method { margin-top: var(--s4); display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .method-step { background: var(--paper); padding: 28px 24px 32px; display: flex; flex-direction: column; gap: var(--s2); min-height: 220px; }
  .method-step .stepnum { font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.18em; color: var(--ink-soft); display: flex; align-items: center; gap: 8px; }
  .method-step .stepnum::before { content: ""; display: inline-block; width: 16px; height: 1px; background: var(--ink); }
  .method-step p { font-size: var(--t-small); line-height: 1.5; color: var(--ink-soft); }
  .method-step h4 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h4); letter-spacing: -0.015em; margin-top: auto; }

  .metrics { margin-top: var(--s4); display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--s4); }
  .metric { border-top: 2px solid var(--ink); padding-top: var(--s2); }
  .metric .figure { font-family: var(--font-display); font-weight: 900; font-size: clamp(40px, 5vw, 64px); letter-spacing: -0.03em; line-height: 1; }
  .metric .figure .unit { font-size: 0.4em; color: var(--ink-soft); margin-left: 4px; letter-spacing: 0; font-weight: 700; }
  .metric .mlabel { font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); margin-top: 12px; line-height: 1.5; }

  @media (max-width: 900px) {
    .hero h1, .hero .deck { grid-column: 1 / 13; }
    .catalogue, .method, .metrics { grid-template-columns: 1fr; }
    }
</style>
