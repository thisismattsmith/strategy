---
import BaseLayout from '../layouts/BaseLayout.astro';
import ChallengeMatcher from '../components/ChallengeMatcher.astro';
import ContactCTA from '../components/ContactCTA.astro';
---
<BaseLayout current="home">
  <main>
    <!-- HERO -->
    <section class="hero">
      <h1>L&amp;D teams do their best work when they are <span class="accent">strategic</span>.</h1>
      <p class="deck">
        A consultancy for L&amp;D teams that want to be <strong>more efficient and more strategic</strong>. We help you cut what isn't working, sharpen what is, and operate with a point of view your business actually values. <strong>One engagement, one outcome, handed over for you to run yourselves.</strong>
      </p>
      <div class="actions">
        <a href="/#contact" class="btn-primary">Contact</a>
        <a href="/services" class="btn-secondary">See our services →</a>
      </div>
    </section>

    <!-- CHALLENGES → SERVICES MATCHER -->
    <ChallengeMatcher />

    <!-- CONTACT -->
    <ContactCTA />
  </main>
</BaseLayout>

<style>
  main { position: relative; z-index: 5; padding: 0 var(--pad-x); max-width: var(--maxw); margin: 0 auto; }

  .hero { padding: var(--s7) 0 var(--s6); display: grid; grid-template-columns: repeat(12, 1fr); gap: var(--s3); align-items: end; }
  .hero h1 { grid-column: 1 / 10; font-family: var(--font-display); font-weight: 900; font-size: var(--t-display); line-height: 0.95; letter-spacing: -0.035em; }
  .hero .deck { grid-column: 1 / 8; font-size: var(--t-deck); line-height: 1.55; margin-top: var(--s4); max-width: 54ch; }
  .hero .actions { grid-column: 1 / 13; margin-top: var(--s4); display: flex; gap: var(--s3); flex-wrap: wrap; align-items: center; }

  .section-header { margin-top: var(--s7); padding-top: var(--s4); border-top: 2px solid var(--ink); }
  .section-header h2 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h2); letter-spacing: -0.025em; line-height: 1; }
  .section-header .desc { margin-top: var(--s2); font-size: var(--t-body); line-height: 1.55; color: var(--ink-soft); max-width: 60ch; }


  .catalogue { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); margin-top: var(--s4); }
  .cat-item { background: var(--paper); padding: var(--s4) 28px 28px; display: grid; grid-template-rows: auto 1fr auto; gap: var(--s3); min-height: 280px; transition: background 0.2s; }
  .cat-item:hover { background: var(--paper-2); }
  .cat-head { display: flex; justify-content: space-between; align-items: baseline; font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-soft); }
  .cat-head strong { color: var(--ink); font-weight: 700; }
  .cat-head .swatch-mini { display: inline-block; width: 9px; height: 9px; border-radius: 50%; vertical-align: middle; margin-right: 7px; }
  .cat-body h3 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h3); letter-spacing: -0.02em; line-height: 1.05; margin-bottom: 10px; }
  .cat-body p { font-size: 14px; line-height: 1.55; color: var(--ink-soft); max-width: 46ch; }
  .cat-foot { display: flex; justify-content: space-between; align-items: center; padding-top: var(--s2); border-top: 1px solid var(--line-soft); }
  .cat-foot .cta { font-weight: 700; font-size: var(--t-small); letter-spacing: 0.02em; color: var(--ink); border-bottom: 1px solid var(--ink); padding-bottom: 3px; }
  .cat-foot .cta:hover { color: var(--signal); border-color: var(--signal); }
  .cat-foot .ref { font-family: var(--font-mono); font-size: var(--t-mono-sm); letter-spacing: 0.14em; color: var(--ink-faint); }

  .principles { margin-top: var(--s4); }
  .principles-list { list-style: none; counter-reset: prin; }
  .principles-list li { counter-increment: prin; border-bottom: 1px dashed var(--line-soft); }
  .principles-list li:first-child { border-top: 1px dashed var(--line-soft); }
  .principles-list li a, .principles-list li .pending {
    display: grid; grid-template-columns: 40px 1fr auto; align-items: baseline; gap: 16px;
    padding: 18px 0; font-size: var(--t-deck); line-height: 1.4; color: var(--ink-soft); transition: color 0.15s;
  }
  .principles-list li a::before, .principles-list li .pending::before {
    content: counter(prin, decimal-leading-zero); font-family: var(--font-mono); font-size: var(--t-mono);
    color: var(--ink-faint); font-weight: 500; letter-spacing: 0.04em;
  }
  .principles-list li a::after { content: "→"; font-family: var(--font-mono); font-size: 14px; color: var(--ink-faint); transition: transform 0.2s ease, color 0.15s; }
  .principles-list li .pending::after { content: "—"; font-family: var(--font-mono); font-size: 14px; color: var(--line-soft); }
  .principles-list li a:hover { color: var(--ink); }
  .principles-list li a:hover::after { transform: translateX(4px); color: var(--signal); }
  .principles-list li .pending { cursor: default; }

  .method { margin-top: var(--s4); display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--line); border: 1px solid var(--line); }
  .method-step { background: var(--paper); padding: 28px 24px 32px; display: flex; flex-direction: column; gap: var(--s2); min-height: 220px; }
  .method-step .stepnum { font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.18em; color: var(--ink-soft); display: flex; align-items: center; gap: 8px; }
  .method-step .stepnum::before { content: ""; display: inline-block; width: 16px; height: 1px; background: var(--ink); }
  .method-step p { font-size: var(--t-small); line-height: 1.5; color: var(--ink-soft); }
  .method-step h4 { font-family: var(--font-display); font-weight: 900; font-size: var(--t-h4); letter-spacing: -0.015em; margin-top: auto; }

  .metrics { margin-top: var(--s4); display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--s4); }
  .metric { border-top: 2px solid var(--ink); padding-top: var(--s2); }
  .metric .figure { font-family: var(--font-display); font-weight: 900; font-size: clamp(40px, 5vw, 64px); letter-spacing: -0.03em; line-height: 1; }
  .metric .figure .unit { font-size: 0.4em; color: var(--ink-soft); margin-left: 4px; letter-spacing: 0; font-weight: 700; }
  .metric .mlabel { font-family: var(--font-mono); font-size: var(--t-mono); letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-soft); margin-top: 12px; line-height: 1.5; }

  @media (max-width: 900px) {
    .hero h1, .hero .deck { grid-column: 1 / 13; }
    .catalogue, .method, .metrics { grid-template-columns: 1fr; }
    }
</style>
