---
// Footer.astro — shared across all pages.
---
<footer class="foot">
  <div>
    <div class="brand"><span class="swatch"></span> Strategic L&amp;D</div>
    <p>A strategy design office for organisations that take learning and development seriously.</p>
  </div>
  <div>
    <h5>Office</h5>
    <ul>
      <li><a href="/catalogue">Catalogue</a></li>
      <li><a href="/#principles">Principles</a></li>
      <li><a href="/blog">Notes</a></li>
      <li><a href="/#commission">Contact</a></li>
    </ul>
  </div>
  <div>
    <h5>Catalogue</h5>
    <ul>
      <li><a href="/catalogue">A-01 / Design Principles</a></li>
      <li><a href="/catalogue">A-02 / Process Design</a></li>
      <li><a href="/catalogue">A-03 / Learning Strategy</a></li>
      <li><a href="/catalogue">A-04 / Strategic Thinking</a></li>
    </ul>
  </div>
  <div>
    <h5>Contact</h5>
    <ul>
      <li>hello@thisismattsmith.com</li>
      <li>Wadawurrung Country, AU</li>
      <li><a href="https://www.linkedin.com/in/thisismattsmith/">LinkedIn ↗</a></li>
    </ul>
  </div>
  <div class="baseline">
    <span>© 2026 Strategic L&amp;D · L&amp;D Strategy Design Office</span>
    <span>Designed and operated on Wadawurrung Country</span>
  </div>
</footer>

<style>
  .foot {
    padding: var(--s5) var(--pad-x) var(--s4);
    max-width: var(--maxw); margin: 0 auto;
    display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: var(--s4);
    border-top: 1px solid var(--line);
  }
  .brand {
    font-family: var(--font-display); font-weight: 900; font-size: 20px;
    letter-spacing: -0.02em; display: flex; align-items: center; gap: 10px;
  }
  .brand .swatch { width: 12px; height: 12px; background: var(--signal); border-radius: 50%; }
  .foot p { margin-top: 12px; font-size: var(--t-small); color: var(--ink-soft); line-height: 1.55; max-width: 36ch; }
  .foot h5 {
    font-family: var(--font-mono); font-size: var(--t-mono-sm); font-weight: 500;
    letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-faint); margin-bottom: var(--s2);
  }
  .foot ul { list-style: none; }
  .foot ul li { font-size: var(--t-small); line-height: 2.0; color: var(--ink-soft); }
  .foot ul li a:hover { color: var(--ink); }
  .baseline {
    grid-column: 1 / -1; margin-top: var(--s4); padding-top: var(--s3);
    border-top: 1px solid var(--line-soft);
    display: flex; justify-content: space-between;
    font-family: var(--font-mono); font-size: var(--t-mono-sm);
    letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink-faint);
  }
  @media (max-width: 900px) { .foot { grid-template-columns: 1fr 1fr; } }
</style>
